generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  userName     String   @db.VarChar(255)
  password     String   @db.Text
  refreshToken String   @db.Text
  salt         String   @db.Text
  name         String   @db.VarChar(255)
  nameNoSign   String   @db.VarChar(255)
  email        String?  @db.VarChar(255)
  sex          Int
  img          String?  @db.Text
  isFriend     Boolean  @default(false)
  date         DateTime @updatedAt

  posts        Post[]
  comments     Comment[]
  likes        Like[]
  memberRooms  MemberRoom[]
  mess         Mess[]
  sentRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedRequests FriendRequest[] @relation("ReceivedFriendRequests")

  user Friendship[] @relation("UserFriends")
  friend Friendship[] @relation("FriendOf")
}

//loi moi ket ban
model FriendRequest{
  id        Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])
 
}

//quan he ban be
model Friendship {
  userId   Int
  friendId Int

  createdAt DateTime @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id])
  friend User @relation("FriendOf", fields: [friendId], references: [id])

}

model Post {
  id        Int      @id @default(autoincrement())
  des       String   @db.LongText
  img       String   @db.Text
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id])
  likes    Like[]
  comments Comment[]
}

model Comment {
  id     Int    @id @default(autoincrement())
  des    String @db.LongText
  userId Int
  postId Int

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model Like {
  id     Int @id @default(autoincrement())
  userId Int
  postId Int 
  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model Room {
  id        Int      @id @default(autoincrement())
  type      Boolean
  title     String   @db.VarChar(255)
  createdAt DateTime @default(now())
  members  MemberRoom[]
  mess Mess[]
}

model MemberRoom {
  id     Int @id @default(autoincrement())
  roomId Int
  userId Int
  joinAt DateTime @default(now())

   room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])

}

model Mess {
  id        Int      @id @default(autoincrement())
  roomId    Int
  senderId  Int
  content   String  @db.LongText
  createdAt DateTime @default(now())
  deletedAt DateTime?
  attachment Attachment[]
  messStatus MessStatus[]

  room        Room        @relation(fields: [roomId], references: [id])
  sender      User        @relation(fields: [senderId], references: [id])
  
}

model MessStatus {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  status    Boolean
  updatedAt DateTime @updatedAt
  
  message Mess @relation(fields: [messageId], references: [id])
}

model Attachment {
  id        Int @id @default(autoincrement())
  messageId Int
  fileUrl   String @db.Text
  fileType  String @db.VarChar(50)
   message Mess @relation(fields: [messageId], references: [id])
}
